<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET"/>
    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/logo"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/logo_round"
        android:supportsRtl="false"
        android:theme="@style/Theme.Pokenamon"
        android:enableOnBackInvokedCallback="true"
        >
        <activity
            android:name=".auth.Login"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".core.Home"
            android:exported="false">
        </activity>
        <activity
            android:name=".core.Battle"
            android:exported="false">
        </activity>
        <activity
            android:name=".core.Collection"
            android:exported="false"
            android:launchMode="singleTop">
        </activity>
        <activity
            android:name=".core.Gacha"
            android:exported="false"
            android:launchMode="singleTop">
        </activity>
        <activity
            android:name=".core.GachaPull"
            android:exported="false"
            android:noHistory="true"
            android:launchMode="singleTask">
        </activity>
        <activity
            android:name=".core.PokemonView"
            android:exported="false"
            android:noHistory="true"
            android:launchMode="singleTask">
        </activity>
        <activity
            android:name=".auth.Register"
            android:exported="false">
        </activity>
    </application>
</manifest>