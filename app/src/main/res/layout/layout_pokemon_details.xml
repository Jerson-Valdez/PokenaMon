<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".helper.PokemonDetail">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="50dp"
        android:paddingBottom="120dp">

        <Button
            android:id="@+id/back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back"
            android:background="@drawable/rectangle"
            android:textSize="20sp"
            android:textAllCaps="false"
            android:textStyle="bold"/>

        <include
            android:id="@+id/pokemonCard"
            layout="@layout/pokemon_card"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Moves"
            android:textColor="@color/text"
            android:textStyle="bold"
            android:textSize="20sp"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:background="@drawable/rectangle"
            android:padding="20dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/move1name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Scratch"
                android:textColor="@color/text"
                android:textStyle="bold"
                android:textSize="20sp"
                android:gravity="center"
                android:layout_marginRight="5dp"
                android:layout_gravity="center"/>

            <TextView
                android:id="@+id/move1pwr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="30 PWR"
                android:textAllCaps="true"
                android:background="@drawable/rect"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:textSize="12sp"
                android:textColor="@color/text"
                android:textStyle="bold"
                android:layout_gravity="center"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:background="@drawable/rectangle"
            android:padding="20dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/move2name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Scratch"
                android:textColor="@color/text"
                android:textStyle="bold"
                android:textSize="20sp"
                android:gravity="center"
                android:layout_marginRight="5dp"
                android:layout_gravity="center"/>

            <TextView
                android:id="@+id/move2pwr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="30 PWR"
                android:textAllCaps="true"
                android:background="@drawable/rect"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:textSize="12sp"
                android:textColor="@color/text"
                android:textStyle="bold"
                android:layout_gravity="center"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:background="@drawable/rectangle"
            android:padding="20dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/move3name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Scratch"
                android:textColor="@color/text"
                android:textStyle="bold"
                android:textSize="20sp"
                android:gravity="center"
                android:layout_marginRight="5dp"
                android:layout_gravity="center"/>

            <TextView
                android:id="@+id/move3pwr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="30 PWR"
                android:textAllCaps="true"
                android:background="@drawable/rect"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:textSize="12sp"
                android:textColor="@color/text"
                android:textStyle="bold"
                android:layout_gravity="center"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:background="@drawable/rectangle"
            android:padding="20dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/move4name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Scratch"
                android:textColor="@color/text"
                android:textStyle="bold"
                android:textSize="20sp"
                android:gravity="center"
                android:layout_marginRight="5dp"
                android:layout_gravity="center"/>

            <TextView
                android:id="@+id/move4pwr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="30 PWR"
                android:textAllCaps="true"
                android:background="@drawable/rect"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:textSize="12sp"
                android:textColor="@color/text"
                android:textStyle="bold"
                android:layout_gravity="center"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/sell"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Sell"
                android:textSize="20sp"
                android:textAllCaps="false"
                android:textColor="@color/primary"
                android:background="@drawable/rectangle"
                android:textStyle="bold"
                app:backgroundTint="@null"
                android:layout_marginRight="10dp"
                android:paddingVertical="10dp"/>

            <Button
                android:id="@+id/select"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Select"
                android:textSize="20sp"
                android:textAllCaps="false"
                android:textColor="@color/text"
                android:background="@drawable/rect"
                android:textStyle="bold"
                app:backgroundTint="@null"
                android:paddingVertical="10dp"/>

        </LinearLayout>

    </LinearLayout>
    
    <include layout="@layout/navbar" />

</RelativeLayout>