<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bottom_nav_bar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_alignParentBottom="true"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="20dp"
    android:padding="10dp"
    android:background="@drawable/card"
    android:gravity="center"
    android:elevation="8dp"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/nav_home"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:src="@drawable/tabler_icon_home_2"
        android:padding="15dp"
        android:background="@drawable/rect"
        />

    <ImageView
        android:id="@+id/nav_battle"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:src="@drawable/tabler_icon_swords"
        android:padding="15dp"
        />

    <ImageView
        android:id="@+id/nav_summon"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:src="@drawable/tabler_icon_pokeballnav"
        android:padding="15dp"
        />

    <ImageView
        android:id="@+id/nav_collection"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:src="@drawable/tabler_icon_librarynav"
        android:padding="15dp"
        />
</LinearLayout>