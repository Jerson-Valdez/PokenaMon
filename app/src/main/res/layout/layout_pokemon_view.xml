<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".core.PokemonView">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:layout_marginTop="40dp"
        >

        <TextView
            android:id="@+id/pokemon_view_backButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back"
            android:textColor="@color/textVariant"
            android:textStyle="bold"
            android:textSize="20sp"
            android:paddingVertical="10dp"
            android:paddingEnd="20dp"
            />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            />

        <TextView
            android:id="@+id/pokemon_view_sellButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sell"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="@color/electric"
            android:paddingVertical="10dp"
            android:paddingHorizontal="20dp"
            android:background="@drawable/gold"
            />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_marginBottom="40dp"
        >
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="100dp"
            android:scrollbars="none"
            >
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginVertical="8dp"
                    >
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        >
                        <ImageView
                            android:id="@+id/pokemon_view_sprite"
                            android:layout_width="150dp"
                            android:layout_height="150dp"
                            />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginVertical="8dp"
                            >
                            <TextView
                                android:id="@+id/pokemon_view_type1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="4dp"
                                android:background="@drawable/type"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="4dp"
                                android:text="Type 1"
                                android:textColor="@color/text"/>

                            <TextView
                                android:id="@+id/pokemon_view_type2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="4dp"
                                android:background="@drawable/type"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="4dp"
                                android:text="Type 2"
                                android:textColor="@color/text"/>
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="4dp"
                        >
                        <TextView
                            android:id="@+id/pokemon_view_entry"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="#0001"
                            android:textStyle="bold"
                            android:textColor="@color/textVariant"
                            android:layout_marginBottom="4dp"/>
                        <TextView
                            android:id="@+id/pokemon_view_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Charizard"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:layout_marginBottom="4dp"/>
                        <TextView
                            android:id="@+id/pokemon_view_rarity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="18sp"
                            android:textColor="@color/electric"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/pokemon_view_level"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lv. 45"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="@color/text"
                            android:layout_marginBottom="4dp"/>
                        <TextView
                            android:id="@+id/pokemon_view_exp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0/456"
                            android:textColor="@color/textVariant"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            />
                        <ProgressBar
                            style="?android:attr/progressBarStyleHorizontal"
                            android:id="@+id/pokemon_view_expBar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:indeterminate="false"
                            android:scaleY="1.5"
                            android:progressBackgroundTint="@color/textVariant"
                            android:progressTint="@color/textVariant"
                            android:max="100"
                            android:progress="56"
                            />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Base Stats"
                    android:textSize="20sp"
                    android:textColor="@color/text"
                    android:textStyle="bold"
                    android:layout_marginVertical="8dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    >

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="16dp"
                        >

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            >
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="HP"
                                android:textSize="14sp"
                                android:textColor="@color/text"
                                android:layout_marginTop="4dp"/>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="4dp"
                                >
                                <ProgressBar
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:id="@+id/pokemon_view_hpBar"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:indeterminate="false"
                                    android:scaleY="1.5"
                                    android:progressBackgroundTint="@color/textVariant"
                                    android:progressTint="@color/textVariant"
                                    android:max="100"
                                    android:progress="0"
                                    android:layout_marginEnd="4dp"
                                    />

                                <TextView
                                    android:id="@+id/pokemon_view_hp"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="255"
                                    android:textSize="14sp"
                                    android:textColor="@color/text"/>
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            >
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Attack"
                                android:textSize="14sp"
                                android:textColor="@color/text"
                                android:layout_marginTop="4dp"/>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="4dp"
                                >
                                <ProgressBar
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:id="@+id/pokemon_view_attackBar"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:indeterminate="false"
                                    android:scaleY="1.5"
                                    android:progressBackgroundTint="@color/textVariant"
                                    android:progressTint="@color/textVariant"
                                    android:max="100"
                                    android:progress="0"
                                    android:layout_marginEnd="4dp"
                                    />

                                <TextView
                                    android:id="@+id/pokemon_view_attack"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="255"
                                    android:textSize="14sp"
                                    android:textColor="@color/text"/>
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            >
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Defense"
                                android:textSize="14sp"
                                android:textColor="@color/text"
                                android:layout_marginTop="4dp"/>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="4dp"
                                >
                                <ProgressBar
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:id="@+id/pokemon_view_defenseBar"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:indeterminate="false"
                                    android:scaleY="1.5"
                                    android:progressBackgroundTint="@color/textVariant"
                                    android:progressTint="@color/textVariant"
                                    android:max="100"
                                    android:progress="0"
                                    android:layout_marginEnd="4dp"
                                    />

                                <TextView
                                    android:id="@+id/pokemon_view_defense"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="255"
                                    android:textSize="14sp"
                                    android:textColor="@color/text"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        >

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            >
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SP. Attack"
                                android:textSize="14sp"
                                android:textColor="@color/text"
                                android:layout_marginTop="4dp"/>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="4dp"
                                >
                                <ProgressBar
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:id="@+id/pokemon_view_spAttackBar"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:indeterminate="false"
                                    android:scaleY="1.5"
                                    android:progressBackgroundTint="@color/textVariant"
                                    android:progressTint="@color/textVariant"
                                    android:max="100"
                                    android:progress="0"
                                    android:layout_marginEnd="4dp"
                                    />

                                <TextView
                                    android:id="@+id/pokemon_view_spAttack"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="255"
                                    android:textSize="14sp"
                                    android:textColor="@color/text"/>
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            >
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SP. Defense"
                                android:textSize="14sp"
                                android:textColor="@color/text"
                                android:layout_marginTop="4dp"/>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="4dp"
                                >
                                <ProgressBar
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:id="@+id/pokemon_view_spDefenseBar"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:indeterminate="false"
                                    android:scaleY="1.5"
                                    android:progressBackgroundTint="@color/textVariant"
                                    android:progressTint="@color/textVariant"
                                    android:max="100"
                                    android:progress="0"
                                    android:layout_marginEnd="4dp"
                                    />

                                <TextView
                                    android:id="@+id/pokemon_view_spDefense"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="255"
                                    android:textSize="14sp"
                                    android:textColor="@color/text"/>
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            >
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Speed"
                                android:textSize="14sp"
                                android:textColor="@color/text"
                                android:layout_marginTop="4dp"/>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="4dp"
                                >
                                <ProgressBar
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:id="@+id/pokemon_view_speedBar"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:indeterminate="false"
                                    android:scaleY="1.5"
                                    android:progressBackgroundTint="@color/textVariant"
                                    android:progressTint="@color/textVariant"
                                    android:max="100"
                                    android:progress="0"
                                    android:layout_marginEnd="4dp"
                                    />

                                <TextView
                                    android:id="@+id/pokemon_view_speed"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="255"
                                    android:textSize="14sp"
                                    android:textColor="@color/text"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Moves"
                    android:textColor="@color/text"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:layout_marginVertical="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    >

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp"
                        >

                        <LinearLayout
                            android:id="@+id/pokemon_view_move1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="8dp"
                            android:gravity="center_vertical"
                            android:background="@drawable/rectangle"
                            android:layout_marginBottom="8dp"
                            >
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                >

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    >
                                    <TextView
                                        android:id="@+id/pokemon_view_move1Name"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Name"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/text"
                                        android:layout_marginEnd="4dp"
                                        />

                                    <Space
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        />

                                    <TextView
                                        android:id="@+id/pokemon_view_move1Pp"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Pp"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/text"
                                        />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:layout_marginTop="8dp"
                                    >
                                    <TextView
                                        android:id="@+id/pokemon_view_move1Type"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:paddingHorizontal="8dp"
                                        android:paddingVertical="4dp"
                                        android:textSize="10sp"
                                        android:textColor="@color/text"
                                        android:background="@drawable/type"/>

                                    <Space
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        />

                                    <TextView
                                        android:id="@+id/pokemon_view_move1Class"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:paddingHorizontal="8dp"
                                        android:paddingVertical="4dp"
                                        android:textSize="10sp"
                                        android:textColor="@color/text"
                                        android:background="@drawable/move_class"
                                        />
                                </LinearLayout>


                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/pokemon_view_move3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="8dp"
                            android:gravity="center_vertical"
                            android:background="@drawable/rectangle"
                            >
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                >

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    >
                                    <TextView
                                        android:id="@+id/pokemon_view_move3Name"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Name"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/text"
                                        />

                                    <Space
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        />

                                    <TextView
                                        android:id="@+id/pokemon_view_move3Pp"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Pp"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/text"
                                        />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:layout_marginTop="8dp"
                                    >
                                    <TextView
                                        android:id="@+id/pokemon_view_move3Type"
                                        android:layout_marginTop="4dp"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:paddingHorizontal="8dp"
                                        android:paddingVertical="4dp"
                                        android:textSize="10sp"
                                        android:textColor="@color/text"
                                        android:background="@drawable/type"/>

                                    <Space
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        />

                                    <TextView
                                        android:id="@+id/pokemon_view_move3Class"
                                        android:layout_marginTop="4dp"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:paddingHorizontal="8dp"
                                        android:paddingVertical="4dp"
                                        android:textSize="10sp"
                                        android:textColor="@color/text"
                                        android:background="@drawable/move_class"
                                        />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        >

                        <LinearLayout
                            android:id="@+id/pokemon_view_move2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="8dp"
                            android:gravity="center_vertical"
                            android:background="@drawable/rectangle"
                            android:layout_marginBottom="8dp"
                            >
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                >

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    >
                                    <TextView
                                        android:id="@+id/pokemon_view_move2Name"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Name"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/text"
                                        android:layout_marginEnd="4dp"
                                        />

                                    <Space
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        />

                                    <TextView
                                        android:id="@+id/pokemon_view_move2Pp"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Pp"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/text"
                                        />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:layout_marginTop="8dp"
                                    >
                                    <TextView
                                        android:id="@+id/pokemon_view_move2Type"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:paddingHorizontal="8dp"
                                        android:paddingVertical="4dp"
                                        android:textSize="10sp"
                                        android:textColor="@color/text"
                                        android:background="@drawable/type"/>

                                    <Space
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        />

                                    <TextView
                                        android:id="@+id/pokemon_view_move2Class"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:paddingHorizontal="8dp"
                                        android:paddingVertical="4dp"
                                        android:textSize="10sp"
                                        android:textColor="@color/text"
                                        android:background="@drawable/move_class"
                                        />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/pokemon_view_move4"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="8dp"
                            android:gravity="center_vertical"
                            android:background="@drawable/rectangle"
                            >
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                >

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    >
                                    <TextView
                                        android:id="@+id/pokemon_view_move4Name"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Name"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/text"
                                        />

                                    <Space
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        />

                                    <TextView
                                        android:id="@+id/pokemon_view_move4Pp"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Pp"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/text"
                                        />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:layout_marginTop="8dp"
                                    >
                                    <TextView
                                        android:id="@+id/pokemon_view_move4Type"
                                        android:layout_marginTop="4dp"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:paddingHorizontal="8dp"
                                        android:paddingVertical="4dp"
                                        android:textSize="10sp"
                                        android:textColor="@color/text"
                                        android:background="@drawable/type"/>

                                    <Space
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        />

                                    <TextView
                                        android:id="@+id/pokemon_view_move4Class"
                                        android:layout_marginTop="4dp"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:paddingHorizontal="8dp"
                                        android:paddingVertical="4dp"
                                        android:textSize="10sp"
                                        android:textColor="@color/text"
                                        android:background="@drawable/move_class"
                                        />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:id="@+id/pokemon_view_selectPokemon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingVertical="12sp"
            android:paddingHorizontal="8dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/rect"
            >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Pokemon"
                android:textColor="@color/textVariant"
                android:textStyle="bold"
                android:textSize="16sp"
                />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>