<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:padding="20dp"
    tools:context=".core.Gacha">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2.5"
            android:text="Summon"
            android:textSize="30sp"
            android:textColor="@color/text"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="2,000"
            android:textAlignment="center"
            android:textStyle="bold"
            android:background="@drawable/gold"
            android:textColor="@color/coin"
            android:textSize="20sp"

            />

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chances of Rarity"
        android:textColor="@color/text"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="10dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Legendary - 5%"
        android:textColor="@color/text"
        android:textSize="16sp"/>
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ultra Rare - 15%"
        android:textColor="@color/text"
        android:textSize="16sp"/>
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Rare - 30%"
        android:textColor="@color/text"
        android:textSize="16sp"/>
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Common - 50%"
        android:textColor="@color/text"
        android:textSize="16sp"/>

    <ImageView
        android:id="@+id/pokeball"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:src="@mipmap/ic_launcher_foreground"
        android:scaleX="4"
        android:scaleY="4"
        android:layout_marginTop="80dp"/>
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mystery Egg"
        android:textColor="@color/text"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginTop="90dp"/>
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Draw to get more pokemon"
        android:textColor="@color/textVariant"
        android:textAlignment="center"
        android:layout_marginTop="10dp"/>

    <Button
        android:id="@+id/draw10x"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Draw 10x - 900 coins"
        android:textStyle="bold"
        android:textColor="@color/text"
        android:textSize="20sp"
        android:layout_marginTop="10dp"
        android:padding="15dp"
        android:textAllCaps="false"
        android:background="@drawable/rect"/>

    <Button
        android:id="@+id/draw1x"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Draw 1x - 100 coins"
        android:textSize="20sp"
        android:layout_marginTop="10dp"
        android:padding="15dp"
        android:textStyle="bold"
        android:textColor="@color/primaryVariant2"
        android:textAllCaps="false"
        android:background="@drawable/card"/>

</LinearLayout>