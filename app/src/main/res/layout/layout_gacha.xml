<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".core.Gacha">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="50dp"
        android:paddingBottom="100dp"
        android:paddingHorizontal="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2.5"
                android:text="Summon"
                android:textSize="25sp"
                android:textColor="@color/text"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/coins"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text=""
                android:textAlignment="center"
                android:textStyle="bold"
                android:background="@drawable/gold"
                android:textColor="@color/coin"
                android:textSize="20sp"
                android:layout_gravity="center"/>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chances of Rarity"
            android:textColor="@color/text"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Legendary - 5%"
            android:textColor="@color/textVariant"
            android:textSize="14sp"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ultra Rare - 15%"
            android:textColor="@color/textVariant"
            android:textSize="14sp"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Rare - 30%"
            android:textColor="@color/textVariant"
            android:textSize="14sp"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Common - 50%"
            android:textColor="@color/textVariant"
            android:textSize="14sp"/>

        <ImageView
            android:id="@+id/pokeball"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:src="@mipmap/ic_launcher_foreground"
            android:scaleX="1.5"
            android:scaleY="1.5"
            android:visibility="visible"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewGacha"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:visibility="gone" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mystery Egg"
            android:textColor="@color/text"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textAlignment="center"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Draw to get more pokemon"
            android:textColor="@color/textVariant"
            android:textAlignment="center"/>

        <Button
            android:id="@+id/draw10x"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Draw 10x - 900 coins"
            android:textStyle="bold"
            android:textColor="@color/text"
            android:textSize="20sp"
            android:layout_marginTop="10dp"
            android:padding="15dp"
            android:textAllCaps="false"
            android:background="@drawable/rect"
            app:backgroundTint="@null"/>

        <Button
            android:id="@+id/draw1x"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Draw 1x - 100 coins"
            android:textSize="20sp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:padding="15dp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:textAllCaps="false"
            android:background="@drawable/card"
            app:backgroundTint="@null"/>

    </LinearLayout>

    <include layout="@layout/navbar" />

</RelativeLayout>